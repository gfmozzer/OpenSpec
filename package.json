{
  "name": "@gfmozzer/opensdd",
  "version": "1.2.1-rc2",
  "description": "AI-native system for spec-driven development",
  "keywords": [
    "opensdd",
    "openspec",
    "specs",
    "cli",
    "ai",
    "development"
  ],
  "homepage": "https://github.com/gfmozzer/OpenSpec",
  "repository": {
    "type": "git",
    "url": "https://github.com/gfmozzer/OpenSpec.git"
  },
  "bugs": {
    "url": "https://github.com/gfmozzer/OpenSpec/issues"
  },
  "license": "MIT",
  "author": "OpenSDD Contributors",
  "type": "module",
  "publishConfig": {
    "access": "public"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "bin": {
    "opensdd": "./bin/opensdd.js"
  },
  "files": [
    "dist",
    "bin",
    "schemas",
    "!dist/**/*.test.js",
    "!dist/**/__tests__",
    "!dist/**/*.map"
  ],
  "scripts": {
    "cleanup": "node scripts/cleanup.mjs",
    "cleanup:install": "node scripts/cleanup.mjs install",
    "lint": "eslint src/",
    "build": "node build.js",
    "dev": "tsc --watch",
    "dev:cli": "pnpm build && node bin/opensdd.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest --coverage",
    "prepublishOnly": "node build.js",
    "check:pack-version": "node scripts/pack-version-check.mjs",
    "release": "pnpm run release:ci",
    "release:ci": "pnpm run check:pack-version && pnpm exec changeset publish",
    "changeset": "changeset"
  },
  "engines": {
    "node": ">=20.19.0"
  },
  "devDependencies": {
    "@changesets/changelog-github": "^0.6.0",
    "@changesets/cli": "^2.30.0",
    "@mermaid-js/mermaid-cli": "^11.12.0",
    "@vitest/coverage-v8": "^3.2.4",
    "@vitest/ui": "^3.2.4",
    "eslint": "^9.39.2",
    "typescript-eslint": "^8.58.2",
    "vitest": "^3.2.4"
  },
  "dependencies": {
    "@inquirer/core": "^11.1.8",
    "@inquirer/prompts": "^8.4.1",
    "@types/node": "^25.6.0",
    "chalk": "^5.6.2",
    "commander": "^14.0.3",
    "fast-glob": "^3.3.3",
    "ora": "^9.3.0",
    "posthog-node": "^5.29.2",
    "typescript": "^6.0.2",
    "yaml": "^2.8.3",
    "zod": "^4.3.6"
  }
}